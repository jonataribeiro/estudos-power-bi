// // - splice -> Altera o array original. Remove, substitui ou adiciona elementos.
//                Formato: .splice(indice_inicial, qtd_deletar, itens_adicionar)


// 💻 Exemplo 1: Apenas Deletando um Item do Meio da Lista
// Imagine que o usuário "Dezembro" se cadastrou no lugar errado
// em uma lista de meses e você quer simplesmente apagá-lo de lá.


const meses = ['Jan', 'Fev', 'Dez', 'Abr'];
meses.splice(2, 1); // Ordem: Vá na posição 2, e delete 1 item dali

console.log(meses); // Resultado: [ 'Jan', 'Fev', 'Abr' ] -> Mudou o original na hora!


// 💻 Exemplo 2: Substituindo um Item (Arranca um e coloca outro)
// Imagine que você quer corrigir o erro do exemplo anterior de forma completa:
// tirar o "Dez" e colocar o "Mar" exatamente na mesma vaga.

const mesesCorrigir = ['Jan', 'Fev', 'Dez', 'Abr'];
mesesCorrigir.splice(2, 1, 'Mar'); // Ordem: Vá na posição 2, delete 1 item ('Dez') e adicione 'Mar' no lugar

console.log(mesesCorrigir); // Resultado: [ 'Jan', 'Fev', 'Mar', 'Abr' ]



// Ordem: Vá na posição 1 (onde está a Calça), delete ZERO itens, e enfie 'Meia' ali
const produtos = ['Camisa', 'Calça', 'Tênis'];

produtos.splice(1, 0, 'Meia');

console.log(produtos);
// Resultado: [ 'Camisa', 'Meia', 'Calça', 'Tênis' ]
// (A Calça e o Tênis foram empurrados para o lado!)


